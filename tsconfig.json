// tsconfig.json
//
// ----------------------------------------------------------------------------
//                                   ОПИСАНИЕ
// ----------------------------------------------------------------------------
// Конфигурация для IDE и локальной разработки. Предназначена для проверки типов,
// навигации и подсветки в редакторе и для запуска тестов. Артефактов не генерирует
// (noEmit: true). Включает:
//
//   • sourceMap для удобной отладки в IDE,
//   • allowImportingTsExtensions для дружбы с NodeNext при работе с .ts/.mts,
//   • анализ исходников и тестов.
//
// Для прод-сборки используется отдельный файл: tsconfig.build.json.
// ----------------------------------------------------------------------------
{
    // Наследует общие параметры из базового конфига.
    "extends": "./tsconfig.base.json",

    "compilerOptions": {
        // --------------------------------------------------------------------
        //                         НАСТРОЙКИ ДЛЯ IDE
        // --------------------------------------------------------------------
        // Запрещает генерацию любых выходных файлов.
        "noEmit": true,
        // Включает генерацию source map для удобной отладки в IDE.
        "sourceMap": true,
        // Разрешает использовать расширения .ts/.mts в путях модулей при импорте.
        "allowImportingTsExtensions": true
        // --------------------------------------------------------------------
    },

    // ----------------------------------------------------------------------
    //                           ГРАНИЦЫ АНАЛИЗА
    // ----------------------------------------------------------------------
    // Включаемые файлы и каталоги для анализа типов.
    "include": ["src", "tests"],
    // Исключаемые файлы и каталоги.
    "exclude": ["dist", "node_modules"]
    // --------------------------------------------------------------------
}

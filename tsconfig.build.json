// tsconfig.build.json
//
// ----------------------------------------------------------------------------
//                                 ОПИСАНИЕ
// ----------------------------------------------------------------------------
// Конфигурация сборки для выпуска артефактов в папку dist. Используется командой
//
//   tsc -p tsconfig.build.json
//
// и в npm-скриптах сборки. Генерирует:
//
//   • JS-файлы, соответствующие настройкам базового конфига,
//   • декларации типов (.d.ts) и карты деклараций,
//   • исходные карты для отладки.
//
// Исключает тесты и рабочие директории, включает инкрементальную компиляцию для
// ускорения повторных сборок. Эта конфигурация должна соответствовать путям,
// указанным в package.json ("main"/"types"/"exports").
// ----------------------------------------------------------------------------
{
    // Наследует общие параметры из базового конфига.
    "extends": "./tsconfig.base.json",

    "compilerOptions": {
        // --------------------------------------------------------------------
        //                         КОМПИЛЯЦИЯ И ВЫВОД
        // --------------------------------------------------------------------
        // Инкрементальная компиляция: кэширует состояние между сборками,
        // чтобы последующие запуски были быстрее. По умолчанию создаёт файл
        // кэша рядом с этим конфигом (tsconfig.build.tsbuildinfo).
        // При желании путь можно зафиксировать опцией "tsBuildInfoFile".
        "incremental": true,
        // Пример (необязательно):
        // "tsBuildInfoFile": "dist/tsconfig.build.tsbuildinfo",

        // Каталог для скомпилированных файлов.
        "outDir": "dist",
        // Корневая папка исходников для корректной структуры вывода.
        "rootDir": "src",
        // Генерация файлов деклараций типов (*.d.ts).
        "declaration": true,
        // Генерация карт деклараций (*.d.ts.map).
        "declarationMap": true,
        // Генерация source map для отладки.
        "sourceMap": true,
        // Исключает внутренние элементы, помеченные как @internal, из публичных .d.ts.
        "stripInternal": true,
        // В режиме сборки эмит разрешён.
        "noEmit": false
        // --------------------------------------------------------------------
    },

    // ----------------------------------------------------------------------
    //                           ГРАНИЦЫ КОМПИЛЯЦИИ
    // ----------------------------------------------------------------------
    // Включаемые файлы и каталоги.
    "include": ["src"],
    // Исключаемые файлы и каталоги.
    "exclude": ["dist", "node_modules", "tests"]
    // ----------------------------------------------------------------------
}

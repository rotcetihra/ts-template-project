// typedoc.json
{
    // --------------------------------------------------------------------
    //                         ВХОД И РЕЗОЛВ ТОЧЕК
    // --------------------------------------------------------------------
    // Входные точки API. При таком варианте документация строится ТОЛЬКО
    // из того, что реэкспортировано из src/index.ts (правильная модель для библиотек).
    "entryPoints": ["src/index.ts"],

    // Стратегия поиска входных точек:
    //  - "resolve"  — использовать указанные entryPoints как файлы/модули.
    //  - "expand"   — обойти каталог целиком (например, при entryPoints: ["src"]).
    "entryPointStrategy": "resolve",

    // Конфиг TypeScript, чтобы TypeDoc понимал NodeNext, пути и строгие правила.
    "tsconfig": "tsconfig.build.json",

    // --------------------------------------------------------------------
    //                          ВЫВОД И МЕТА
    // --------------------------------------------------------------------
    // Куда складывать сгенерированную документацию.
    "out": "docs",

    // Отображаемое имя проекта.
    "name": "@rotcetihra/ts-template-project",

    // Какой README показывать на главной странице (или "none", чтобы не тащить файл).
    "readme": "README.md",

    // Удалять содержимое папки out перед генерацией (хозяйственность — наше всё).
    "cleanOutputDir": true,

    // Добавлять версию из package.json в заголовок.
    "includeVersion": true,

    // Закрепить ревизию гита для ссылок на исходники (если включены ссылки на исходники).
    "gitRevision": "HEAD",

    // --------------------------------------------------------------------
    //                         ФИЛЬТРЫ ВИДИМОСТИ
    // --------------------------------------------------------------------
    // Исключать внешние декларации (из node_modules).
    "excludeExternals": true,
    // Убрать приватные члены.
    "excludePrivate": true,
    // Защищённые оставляем видимыми (false). Поставь true, если хочешь скрыть.
    "excludeProtected": false,
    // Спрятать элементы, помеченные @internal (дублирует идею stripInternal в tsconfig).
    "excludeInternal": true,
    // Исключать то, что не задокументировано комментариями. Полезно для вылизанного API.
    // Поставь true, если хочешь видеть только то, что с JSDoc.
    "excludeNotDocumented": false,

    // --------------------------------------------------------------------
    //                        НАВИГАЦИЯ И ГРУППИРОВКА
    // --------------------------------------------------------------------
    // Группировать элементы по категориям (теги @category).
    "categorizeByGroup": true,
    // Порядок сортировки в списках.
    // Доступные значения: "source-order", "alphabetical", "kind".
    "sort": ["source-order", "kind", "alphabetical"],

    // --------------------------------------------------------------------
    //                           ТЕМА И ПЛАГИНЫ
    // --------------------------------------------------------------------
    // Тема оформления. Пакет темы уже у тебя в devDependencies.
    "theme": "typedoc-github-theme",
    // Список плагинов TypeDoc.
    "plugin": [
        // Ссылки на MDN для встроенных типов и веб-API.
        "typedoc-plugin-mdn-links",
        // Переименовывает default-экспорт в его исходное имя.
        "typedoc-plugin-rename-defaults"
    ],

    // --------------------------------------------------------------------
    //                           ВАЛИДАЦИЯ
    // --------------------------------------------------------------------
    // Подсветка проблем при генерации.
    "validation": {
        // Предупреждать, если символ использован, но не экспортирован из входных точек.
        "notExported": true,
        // Предупреждать об битых/некорректных ссылках в комментариях.
        "invalidLink": true,
        // Предупреждать о сущностях без документации (если хочешь дресс-контроль).
        "notDocumented": false
    },
    // Считать предупреждения ошибками (под CI ужесточай до true).
    "treatWarningsAsErrors": false
}

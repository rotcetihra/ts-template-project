{
    "name": "@rotcetihra/ts-template-project",
    "version": "0.2.16",
    "description": "Шаблонный преднастроенный TypeScript проект.",
    "keywords": [
        "template",
        "project",
        "ts",
        "typescript"
    ],
    "type": "module",
    "homepage": "https://github.com/rotcetihra/ts-template-project/#readme",
    "bugs": "https://github.com/rotcetihra/ts-template-project/issues",
    "license": "MIT",
    "author": {
        "name": "Arhitector",
        "email": "rotcetihra@mail.ru",
        "url": "https://github.com/rotcetihra"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rotcetihra/ts-template-project.git"
    },
    "scripts": {
        "prepare": "npm run src:build",
        "prepublishOnly": "npm test && npm run build",
        "build": "npm run src:build && npm run docs:build",
        "clean": "npm run src:clean && npm run docs:clean",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
        "src:clean": "rimraf dist",
        "src:build": "npm run src:clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "docs:clean": "rimraf docs",
        "docs:build": "npm run docs:clean && typedoc",
        "docs:serve": "http-server docs -o"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^24.5.2",
        "http-server": "^14.1.1",
        "jest": "^29.7.0",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.1.2",
        "ts-jest-resolver": "^2.0.1",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typedoc": "^0.28.10",
        "typedoc-github-theme": "^0.3.1",
        "typedoc-plugin-mdn-links": "^5.0.9",
        "typedoc-plugin-rename-defaults": "^0.7.3",
        "typescript": "^5.9.2"
    },
    "engines": {
        "node": ">=18"
    },
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    }
}

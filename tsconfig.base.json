// tsconfig.base.json
//
// ----------------------------------------------------------------------------
//                                 ОПИСАНИЕ
// ----------------------------------------------------------------------------
// Базовая конфигурация TypeScript, общая для проекта. Здесь задаются:
//
//   • целевая версия языка и набор стандартных библиотек,
//   • модель модулей (NodeNext) и правила их разрешения,
//   • строгие проверки типов и флаги совместимости,
//   • общие правила резолва путей (baseUrl/paths) и глобальные типы (Node).
//
// Файл расширяется средовыми конфигурациями: tsconfig.json (IDE) и
// tsconfig.build.json (сборка).
// ----------------------------------------------------------------------------
{
    "compilerOptions": {
        // --------------------------------------------------------------------
        //                          ЯЗЫК И ОКРУЖЕНИЕ
        // --------------------------------------------------------------------
        // Версия ECMAScript, в которую будет транслироваться код.
        "target": "ES2022",
        // Набор библиотек с объявлениями типов, соответствующих целевой среде.
        "lib": ["ES2022"],
        // Список глобальных пакетов типов, подключаемых к проекту.
        // Здесь добавляем типы Node.js, чтобы были определены process, Buffer, import.meta и т. п.
        "types": ["node", "jest"],
        // --------------------------------------------------------------------

        // --------------------------------------------------------------------
        //                               МОДУЛИ
        // --------------------------------------------------------------------
        // Система модулей для генерации кода. NodeNext поддерживает ESM и CommonJS в Node.js.
        "module": "NodeNext",
        // Алгоритм поиска модулей. NodeNext соответствует правилам Node.js.
        "moduleResolution": "NodeNext",
        // Определяет, какие файлы считаются модулями.
        // "force" — каждый файл трактуется как модуль даже без import/export.
        // Это убирает «скриптовое» поведение и делает модульность явной везде.
        "moduleDetection": "force",
        // --------------------------------------------------------------------

        // --------------------------------------------------------------------
        //                           ПРОВЕРКА ТИПОВ
        // --------------------------------------------------------------------
        // Включает все строгие проверки типов.
        "strict": true,
        // Интерпретирует опциональные свойства строго, без неявного добавления undefined.
        "exactOptionalPropertyTypes": true,
        // Добавляет undefined к результату при доступе по индексу.
        "noUncheckedIndexedAccess": true,
        // Переменные в блоке catch имеют тип unknown вместо any.
        "useUnknownInCatchVariables": true,
        // --------------------------------------------------------------------

        // --------------------------------------------------------------------
        //                         КОМПИЛЯЦИЯ И ВЫВОД
        // --------------------------------------------------------------------
        // Требует, чтобы каждый файл можно было транслировать изолированно.
        "isolatedModules": true,
        // Пропускает проверку типов в файлах деклараций (.d.ts).
        "skipLibCheck": true,
        // Обеспечивает совместимость с CommonJS-модулями при использовании import.
        "esModuleInterop": true,
        // Разрешает импорт файлов .json.
        "resolveJsonModule": true,
        // Сохраняет синтаксис import/export без переписывания.
        "verbatimModuleSyntax": true,
        // Требует согласованного написания имён файлов с учётом регистра.
        "forceConsistentCasingInFileNames": true,
        // --------------------------------------------------------------------

        // --------------------------------------------------------------------
        //                         РАЗРЕШЕНИЕ МОДУЛЕЙ
        // --------------------------------------------------------------------
        // Базовый каталог для разрешения неотносительных импортов.
        "baseUrl": ".",
        // Переопределения путей для импортов.
        "paths": {
            // Импорты вида "@/..." будут ссылаться на каталог src.
            "@/*": ["src/*"],
            // Импорты вида "tests/..." будут ссылаться на каталог tests.
            "tests/*": ["tests/*"]
        }
        // --------------------------------------------------------------------
    }
}
